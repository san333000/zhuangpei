page {
  background: #FAF9F6;
  color: #2C2C2C;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  line-height: 1.4;
  box-sizing: border-box;
  padding-top: calc(constant(safe-area-inset-top) + 12rpx);
  padding-top: calc(env(safe-area-inset-top) + 12rpx);
  padding-bottom: calc(constant(safe-area-inset-bottom) + 12rpx);
  padding-bottom: calc(env(safe-area-inset-bottom) + 12rpx);
  min-height: 100vh;
  min-height: -webkit-fill-available;
  overflow-x: hidden;
}

.page-shell {
  min-height: 100vh;
  padding-bottom: calc(140rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.serif {
  font-family: "Times New Roman", Georgia, serif;
}

.card {
  background: #FFFCF7;
  border-radius: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(212, 175, 55, 0.08);
}

.muted {
  color: #8E8E8E;
}

.btn-primary {
  background: #D4AF37;
  color: #FFFCF7;
  border-radius: 999rpx;
  font-size: 24rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.btn-outline {
  border: 2rpx solid #D4AF37;
  color: #D4AF37;
  background: #FFFCF7;
  border-radius: 999rpx;
  font-size: 24rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.section-title {
  font-size: 44rpx;
  margin-bottom: 20rpx;
}

.tag {
  background: #F4F4F4;
  color: #8E8E8E;
  font-size: 20rpx;
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
}
